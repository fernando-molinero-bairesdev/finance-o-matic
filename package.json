{
  "name": "finance-o-matic",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "generate:types": "pnpm --filter @finance-o-matic/types generate",
    "db:migrate": "pnpm --filter @finance-o-matic/api db:migrate",
    "db:revision": "pnpm --filter @finance-o-matic/api db:revision --",
    "db:downgrade": "pnpm --filter @finance-o-matic/api db:downgrade"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  }
}
