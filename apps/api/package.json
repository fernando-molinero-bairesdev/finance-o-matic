{
  "name": "@finance-o-matic/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "build": "python -m compileall app",
    "test": "python -m pytest",
    "lint": "python -m ruff check app tests",
    "typecheck": "python -m mypy app",
    "openapi:export": "python scripts/export_openapi.py",
    "seed:currencies": "python scripts/seed_currencies.py",
    "db:migrate": "python -m alembic upgrade head",
    "db:revision": "python -m alembic revision --autogenerate",
    "db:downgrade": "python -m alembic downgrade -1"
  }
}
